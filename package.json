{
  "name": "ml-b2b-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:all": "npm run db:start && npm run dev",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node server/index.js",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "db:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-postgres.ps1",
    "db:status": "powershell -ExecutionPolicy Bypass -File scripts/status-postgres.ps1",
    "convert:inventory": "node scripts/convert-inventory-xls.js",
    "deploy:start": "powershell -ExecutionPolicy Bypass -File scripts/deploy-start.ps1",
    "deploy:stop": "powershell -ExecutionPolicy Bypass -File scripts/deploy-stop.ps1",
    "start": "node server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "shell-quote": "1.8.4"
  }
}
